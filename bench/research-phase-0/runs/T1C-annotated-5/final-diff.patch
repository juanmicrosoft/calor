+    // Helper: if every order line item has an equal or greater quantity in shipments
+    // that are InTransit or Delivered, promote the order to Shipped.
+    private async Task TryPromoteOrderToShippedAsync(Guid orderId, CancellationToken ct)
+    {
+        var order = await _orders.GetByIdAsync(orderId, ct);
+        if (order is null) return;
+        if (order.Status != OrderStatus.Paid) return;
+
+        var shipments = await _shipments.GetByOrderAsync(orderId, ct);
+        var shippedQuantities = shipments
+            .Where(s => s.Status == ShipmentStatus.InTransit || s.Status == ShipmentStatus.Delivered)
+            .SelectMany(s => s.LineItems)
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(x => x.Quantity));
+
+        var allShipped = order.LineItems.All(oli =>
+            shippedQuantities.TryGetValue(oli.Id, out var q) && q >= oli.Quantity);
+
+        if (allShipped && order.LineItems.Count > 0)
+        {
+            order.Status = OrderStatus.Shipped;
+            order.ShippedAt = DateTimeOffset.UtcNow;
+            await _orders.UpdateAsync(order, ct);
+        }
+    }
