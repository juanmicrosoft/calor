+    public async Task<List<Shipment>> GetShipmentsForOrderAsync(Guid orderId, CancellationToken ct = default)
+    {
+        var shipments = await _shipments.GetByOrderAsync(orderId, ct);
+        // Hydrate each shipment's LineItems collection from the line item store.
+        foreach (var s in shipments)
+        {
+            if (s.LineItems.Count == 0)
+            {
+                var lineItems = await _shipments.GetLineItemsAsync(s.Id, ct);
+                s.LineItems.AddRange(lineItems);
+            }
+        }
+        return shipments;
+    }
+
+    /// <summary>
+    /// If every line-item quantity in the order has been covered by shipments
+    /// that are at least InTransit, transition the order to Shipped.
+    /// </summary>
+    private async Task ReevaluateOrderShippedAsync(Order order, CancellationToken ct)
+    {
+        if (order.Status != OrderStatus.Paid)
+            return;
+
+        var allShipments = await _shipments.GetByOrderAsync(order.Id, ct);
+        // Only count shipments that have actually shipped (InTransit or Delivered).
+        var shippedShipmentIds = allShipments
+            .Where(s => s.Status == ShipmentStatus.InTransit || s.Status == ShipmentStatus.Delivered)
+            .Select(s => s.Id)
+            .ToHashSet();
+        if (shippedShipmentIds.Count == 0)
+            return;
+
+        var allLineItemRecords = await _shipments.GetLineItemsByOrderAsync(order.Id, ct);
+        var shippedQty = allLineItemRecords
+            .Where(sli => shippedShipmentIds.Contains(sli.ShipmentId))
+            .GroupBy(sli => sli.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(x => x.Quantity));
+
+        foreach (var li in order.LineItems)
+        {
+            if (shippedQty.GetValueOrDefault(li.Id, 0) < li.Quantity)
+                return; // Not yet fully shipped.
+        }
+
+        order.Status = OrderStatus.Shipped;
+        order.ShippedAt = DateTimeOffset.UtcNow;
+        await _orders.UpdateAsync(order, ct);
+    }
