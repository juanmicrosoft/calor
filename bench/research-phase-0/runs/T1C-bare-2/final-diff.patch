+    /// <summary>
+    /// Sums the quantity already-shipped per OrderLineItem across all shipments for an order.
+    /// </summary>
+    private async Task<Dictionary<Guid, int>> ShippedQuantitiesAsync(Guid orderId, CancellationToken ct)
+    {
+        var allLineItems = await _shipments.GetLineItemsByOrderAsync(orderId, ct);
+        return allLineItems
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(x => x.Quantity));
+    }
+
+    /// <summary>
+    /// If every order line item is now fully covered by shipments, transition the order to Shipped.
+    /// No-op otherwise.
+    /// </summary>
+    private async Task TryTransitionOrderToShippedAsync(Order order, CancellationToken ct)
+    {
+        var shipped = await ShippedQuantitiesAsync(order.Id, ct);
+        var allCovered = order.LineItems.All(li =>
+            shipped.TryGetValue(li.Id, out var qty) && qty >= li.Quantity);
+        if (allCovered && order.Status == OrderStatus.Paid)
+        {
+            order.Status = OrderStatus.Shipped;
+            order.ShippedAt = DateTimeOffset.UtcNow;
+            await _orders.UpdateAsync(order, ct);
+        }
+    }
