+    /// <summary>
+    /// Aggregates already-shipped quantities for an order, treating Pending/InTransit/Delivered
+    /// shipments as committed (only Failed is excluded).
+    /// </summary>
+    private static Dictionary<Guid, int> ComputeShippedQuantities(IEnumerable<Shipment> shipments)
+    {
+        var result = new Dictionary<Guid, int>();
+        foreach (var s in shipments)
+        {
+            if (s.Status == ShipmentStatus.Failed) continue;
+            foreach (var li in s.LineItems)
+            {
+                result.TryGetValue(li.OrderLineItemId, out var prior);
+                result[li.OrderLineItemId] = prior + li.Quantity;
+            }
+        }
+        return result;
+    }
+
+    /// <summary>
+    /// If every order line item is fully covered by non-Pending, non-Failed shipments,
+    /// transition the parent order Paid -> Shipped.
+    /// </summary>
+    private async Task TryAdvanceOrderToShippedAsync(Guid orderId, CancellationToken ct)
+    {
+        var order = await _orders.GetByIdAsync(orderId, ct);
+        if (order is null) return;
+        if (order.Status != OrderStatus.Paid) return;
+
+        var shipments = await _shipments.GetByOrderAsync(orderId, ct);
+
+        // For "shipped" to be true, every line item's quantity must be covered by shipments
+        // that are at least InTransit (Pending shipments don't count — items still in the warehouse).
+        var coverage = new Dictionary<Guid, int>();
+        foreach (var s in shipments)
+        {
+            if (s.Status != ShipmentStatus.InTransit && s.Status != ShipmentStatus.Delivered) continue;
+            foreach (var li in s.LineItems)
+            {
+                coverage.TryGetValue(li.OrderLineItemId, out var prior);
+                coverage[li.OrderLineItemId] = prior + li.Quantity;
+            }
+        }
+
+        foreach (var line in order.LineItems)
+        {
+            coverage.TryGetValue(line.Id, out var shipped);
+            if (shipped < line.Quantity) return; // not fully shipped yet
+        }
+
+        order.Status = OrderStatus.Shipped;
+        order.ShippedAt = DateTimeOffset.UtcNow;
+        await _orders.UpdateAsync(order, ct);
+        _logger.Info("ShipmentService.OrderAutoShipped", new { orderId });
+    }
