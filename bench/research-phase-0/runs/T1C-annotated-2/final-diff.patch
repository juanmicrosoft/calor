+    /// <summary>
+    /// If every OrderLineItem on <paramref name="orderId"/> has been fully
+    /// covered by in-transit (or delivered) shipments and the order is still
+    /// Paid, promote it to Shipped. Otherwise leave the status untouched
+    /// (partial fulfillment keeps the order in Paid).
+    /// </summary>
+    private async Task PromoteOrderIfFullyShippedAsync(Guid orderId, CancellationToken ct)
+    {
+        var order = await _orders.GetByIdAsync(orderId, ct);
+        if (order is null) return;
+        if (order.Status != OrderStatus.Paid) return;
+
+        var lineItems = order.LineItems.Count > 0
+            ? order.LineItems
+            : await _orders.GetLineItemsAsync(orderId, ct);
+        if (lineItems.Count == 0) return;
+
+        var allShipments = await _shipments.GetByOrderAsync(orderId, ct);
+
+        // Only quantities that have been dispatched (InTransit or Delivered) count
+        // toward "shipped". Pending shipments don't promote the order.
+        var shippedByLine = allShipments
+            .Where(s => s.Status is ShipmentStatus.InTransit or ShipmentStatus.Delivered)
+            .SelectMany(s => s.LineItems)
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(x => x.Quantity));
+
+        bool allCovered = lineItems.All(li =>
+            shippedByLine.TryGetValue(li.Id, out var qty) && qty >= li.Quantity);
+
+        if (allCovered)
+        {
+            order.Status = OrderStatus.Shipped;
+            order.ShippedAt = DateTimeOffset.UtcNow;
+            await _orders.UpdateAsync(order, ct);
+            _logger.Info("ShipmentService.OrderFullyShipped", new { orderId });
