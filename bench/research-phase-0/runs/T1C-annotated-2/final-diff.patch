+    public Task<List<ShipmentLineItem>> GetLineItemsForOrderAsync(Guid orderId, CancellationToken ct = default) =>
+        Task.FromResult(_db.WithLock(() =>
+        {
+            var shipmentIds = _db.Shipments.Where(s => s.OrderId == orderId).Select(s => s.Id).ToHashSet();
+            return _db.ShipmentLineItems.Where(li => shipmentIds.Contains(li.ShipmentId)).ToList();
+        }));
+
