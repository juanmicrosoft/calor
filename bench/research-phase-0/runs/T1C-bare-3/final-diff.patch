+    /// <summary>
+    /// Promotes the order to OrderStatus.Shipped if every line item has been fully
+    /// shipped across all of its shipments. No-op otherwise — the order remains Paid.
+    /// </summary>
+    private async Task TryPromoteOrderToShippedAsync(Order order, CancellationToken ct)
+    {
+        var shippedItems = await _shipments.GetLineItemsForOrderAsync(order.Id, ct);
+        var shippedByLineItem = shippedItems
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(li => li.Quantity));
+
+        var allFullyShipped = order.LineItems.All(li =>
+            shippedByLineItem.TryGetValue(li.Id, out var qty) && qty >= li.Quantity);
+
+        if (!allFullyShipped) return;
+
+        // Re-load the order to avoid stomping on concurrent state changes.
+        var fresh = await _orders.GetByIdAsync(order.Id, ct);
+        if (fresh is null) return;
+        if (fresh.Status != OrderStatus.Paid) return;
+
+        fresh.Status = OrderStatus.Shipped;
+        fresh.ShippedAt = DateTimeOffset.UtcNow;
+        await _orders.UpdateAsync(fresh, ct);
+    }
