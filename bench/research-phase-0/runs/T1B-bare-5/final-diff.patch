+    public async Task<StockReservation> ExpireAsync(Guid reservationId, CancellationToken ct = default)
+    {
+        var reservation = await GetReservationOrThrow(reservationId, ct);
+        if (reservation.Status != ReservationStatus.Created)
+            throw new InvalidOperationException($"Cannot expire reservation in status {reservation.Status}.");
+
+        var item = await _inventory.GetBySkuAsync(reservation.Sku, ct);
+        if (item is not null)
+        {
+            item.Reserved -= reservation.Quantity;
+            if (item.Reserved < 0) item.Reserved = 0;
+            await _inventory.UpdateAsync(item, ct);
+        }
+
+        reservation.Status = ReservationStatus.Released;
+        reservation.ReleasedAt = DateTimeOffset.UtcNow;
+        await _inventory.UpdateReservationAsync(reservation, ct);
+
+        await _notifications.NotifyAsync(
+            topic: "reservation.expired",
+            message: $"Reservation {reservation.Id} expired and was released.",
+            payload: new
+            {
+                reservationId = reservation.Id,
+                orderId = reservation.OrderId,
+                sku = reservation.Sku.Value,
+                quantity = reservation.Quantity,
+                expiredAt = reservation.ReleasedAt,
+            },
+            ct);
+
+        _logger.Info("InventoryService.ExpireAsync", new { reservationId = reservation.Id });
+        return reservation;
+    }
+
+    public async Task<int> ExpireDueReservationsAsync(DateTimeOffset asOf, CancellationToken ct = default)
+    {
+        var due = await _inventory.GetExpiredUnconfirmedReservationsAsync(asOf, ct);
+        var expiredCount = 0;
+        foreach (var r in due)
+        {
+            try
+            {
+                await ExpireAsync(r.Id, ct);
+                expiredCount++;
+            }
+            catch (InvalidOperationException ex)
+            {
+                // Reservation could have transitioned (Confirmed/Released/Fulfilled) between
+                // the query and the expire call — log and move on.
+                _logger.Info("InventoryService.ExpireDueReservationsAsync skip", new { reservationId = r.Id, reason = ex.Message });
+            }
+        }
+        return expiredCount;
+    }
