+    // EFFECTS: db:r, db:w, log, mem:w. POSTCONDITION: every reservation in Created status older than ReservationLifetime is Released, its quantity returned to its inventory item's available pool, and a notification is sent.
+    public async Task<int> ProcessExpirationsAsync(CancellationToken ct = default)
+    {
+        var now = _timeProvider.GetUtcNow();
+        var cutoff = now - ReservationLifetime;
+        var expired = await _inventory.GetExpiredCreatedReservationsAsync(cutoff, ct);
+
+        int processed = 0;
+        foreach (var reservation in expired)
+        {
+            ct.ThrowIfCancellationRequested();
+
+            // Defensive: someone may have mutated the reservation concurrently; re-check status.
+            if (reservation.Status != ReservationStatus.Created)
+                continue;
+
+            var item = await _inventory.GetBySkuAsync(reservation.Sku, ct);
+            if (item is not null)
+            {
+                item.Reserved -= reservation.Quantity;
+                if (item.Reserved < 0) item.Reserved = 0;
+                await _inventory.UpdateAsync(item, ct);
+            }
+
+            reservation.Status = ReservationStatus.Released;
+            reservation.ReleasedAt = now;
+            await _inventory.UpdateReservationAsync(reservation, ct);
+
+            _logger.Info(
+                "reservation expired",
+                new { reservationId = reservation.Id, orderId = reservation.OrderId, sku = reservation.Sku.Value, quantity = reservation.Quantity });
+
+            if (_notifications is not null)
+            {
+                await _notifications.NotifyAsync(
+                    topic: "reservation.expired",
+                    message: $"Reservation {reservation.Id} expired and was released.",
+                    payload: new
+                    {
+                        reservationId = reservation.Id,
+                        orderId = reservation.OrderId,
+                        sku = reservation.Sku.Value,
+                        quantity = reservation.Quantity,
+                        createdAt = reservation.CreatedAt,
+                        releasedAt = reservation.ReleasedAt,
+                    },
+                    ct);
+            }
+
+            processed++;
+        }
+
+        return processed;
+    }
