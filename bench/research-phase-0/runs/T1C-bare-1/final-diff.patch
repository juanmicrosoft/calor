+            {
+                var shipped = alreadyShipped.GetValueOrDefault(li.Id, 0);
+                var remaining = li.Quantity - shipped;
+                if (remaining > 0)
+                    defaulted.Add(new ShipmentLineItemRequest(li.Id, remaining));
+            }
+            items = defaulted;
+        }
+
+        if (items.Count == 0)
