+            .SelectMany(s => s.LineItems)
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(li => li.Quantity));
+
+        // Default: ship everything that isn't already on a shipment.
+        if (items == null || items.Count == 0)
+        {
+            var defaulted = new List<ShipmentLineItemRequest>();
