+    public Task<List<Shipment>> GetShipmentsForOrderAsync(Guid orderId, CancellationToken ct = default) =>
+        _shipments.GetByOrderAsync(orderId, ct);
+
+    /// <summary>
+    /// If every order line item now has total in-transit-or-delivered quantity
+    /// equal to its ordered quantity, transitions the order to Shipped. No-op
+    /// otherwise. Pending shipments do not count (the goods haven't left yet).
+    /// </summary>
+    private async Task TryTransitionOrderToShippedAsync(Guid orderId, CancellationToken ct)
+    {
+        var order = await _orders.GetByIdAsync(orderId, ct);
+        if (order == null || order.Status != OrderStatus.Paid) return;
+
+        var allShipments = await _shipments.GetByOrderAsync(orderId, ct);
+        var shippedQty = allShipments
+            .Where(s => s.Status == ShipmentStatus.InTransit || s.Status == ShipmentStatus.Delivered)
+            .SelectMany(s => s.LineItems)
+            .GroupBy(li => li.OrderLineItemId)
+            .ToDictionary(g => g.Key, g => g.Sum(li => li.Quantity));
+
+        var fullyShipped = order.LineItems.All(li =>
+            shippedQty.GetValueOrDefault(li.Id, 0) >= li.Quantity);
+
+        if (fullyShipped && order.LineItems.Count > 0)
+        {
+            order.Status = OrderStatus.Shipped;
+            order.ShippedAt = DateTimeOffset.UtcNow;
+            await _orders.UpdateAsync(order, ct);
+        }
+    }
