§M{m001:DocumentStore}

§F{f001:Persist:pub}
  §I{str:key}
  §I{str:content}
  §O{bool}
  §E{db:w}
  §C{DbContext.SaveChanges} §/C
  §R BOOL:true
§/F{f001}

§F{f002:Load:pub}
  §I{str:key}
  §O{str}
  §E{db:r}
  §R STR:""
§/F{f002}

§F{f003:PersistAndLog:pub}
  §I{str:key}
  §I{str:content}
  §O{bool}
  §E{db:w,cw}
  §B{success:bool} §C{Persist} §A key §A content §/C
  §C{Console.WriteLine} §A (+ STR:"Saved document: " key) §/C
  §R success
§/F{f003}

§/M{m001}
