§M{m001:DataService}

§F{f001:WriteRecord:pri}
  §I{str:key}
  §I{str:value}
  §O{bool}
  §E{db:w}
  §C{DbContext.SaveChanges} §/C
  §R BOOL:true
§/F{f001}

§F{f002:CreateUser:pub}
  §I{str:name}
  §I{str:email}
  §O{bool}
  §E{cw}
  §C{Console.WriteLine} §A (+ STR:"Creating user: " name) §/C
  §B{success:bool} §C{WriteRecord} §A STR:"user" §A name §/C
  §C{Console.WriteLine} §A STR:"Done" §/C
  §R success
§/F{f002}

§/M{m001}
