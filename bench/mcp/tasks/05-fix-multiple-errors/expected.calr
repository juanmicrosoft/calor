§M{m001:Logger}

§F{f001:LogMessage:pub}
  §I{str:message}
  §O{void}
  §E{cw}
  §C{Console.WriteLine} §A message §/C
  §IF{if01} (== INT:1 INT:1)
    §C{Console.WriteLine} §A STR:"Extra log" §/C
  §/I{if01}
§/F{f001}

§F{f002:FormatError:pub}
  §I{str:error}
  §O{str}
  §R (+ STR:"ERROR: " error)
§/F{f002}

§/M{m001}
