§M{m001:PaymentService}

§F{f001:ProcessPayment:pub}
  §I{str:cardNumber}
  §I{f64:amount}
  §O{bool}
  §E{db:w,cw}
  §Q (> amount FLOAT:0.0)
  §C{Console.WriteLine} §A (+ STR:"Processing payment: $" amount) §/C
  §C{DbContext.SaveChanges} §/C
  §R BOOL:true
§/F{f001}

§F{f002:GetBalance:pub}
  §I{str:accountId}
  §O{f64}
  §E{db:r}
  §R FLOAT:0.0
§/F{f002}

§/M{m001}
