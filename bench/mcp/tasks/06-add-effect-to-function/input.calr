§M{m001:UserService}

§F{f001:SaveUser:pub}
  §I{str:name}
  §I{str:email}
  §O{bool}
  §E{db:w}
  §C{Console.WriteLine} §A (+ STR:"Saving user: " name) §/C
  §C{DbContext.SaveChanges} §/C
  §C{Console.WriteLine} §A STR:"User saved" §/C
  §R BOOL:true
§/F{f001}

§F{f002:GetUser:pub}
  §I{str:email}
  §O{str}
  §E{db:r}
  §R STR:""
§/F{f002}

§/M{m001}
