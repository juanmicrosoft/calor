§M{m001:Validator}

§F{f001:IsPositive:pub}
  §I{i32:n}
  §O{bool}
  §R (> n INT:0)
§/F{f001}

§F{f002:IsEven:pub}
  §I{i32:n}
  §O{bool}
  §R (== (% n INT:2) INT:0)
§/F{f002}

§F{f003:IsInRange:pub}
  §I{i32:n}
  §I{i32:lo}
  §I{i32:hi}
  §O{bool}
  §Q (<= lo hi)
  §R (&& (>= n lo) (<= n hi))
§/F{f003}

§/M{m001}
