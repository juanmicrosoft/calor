§M{m001:PatternDemo}
  §F{f001:GetGrade:pub} (i32:score) -> str
    §W{sw1:expr} score
      §K §PREL{gte} 90 → "A"
      §K §PREL{gte} 80 → "B"
      §K §PREL{gte} 70 → "C"
      §K §PREL{gte} 60 → "D"
      §K _ → "F"

  §F{f002:GetHttpStatus:pub} (i32:code) -> str
    §W{sw2:expr} code
      §K 200 → "OK"
      §K 404 → "Not Found"
      §K 500 → "Server Error"
      §K _ → "Unknown"

  §F{f003:Describe:pub} (i32:x) -> str
    §W{sw3:expr} x
      §K §VAR{n} §WHEN (> n 100) → "large"
      §K §VAR{n} §WHEN (< n 0) → "negative"
      §K 0 → "zero"
      §K _ → "normal"

