§M{m001:Contracts}
  §F{f001:Main:pub} () -> void
    §E{cw}
    §C{Console.WriteLine} §A "Testing contracts..." §/C

  §F{f002:Square:pub} (i32:x) -> i32
    §Q (>= x 0)
    §S (>= result 0)
    §R (* x x)

  §F{f003:Divide:pub} (i32:a, i32:b) -> i32
    §Q{"divisor must not be zero"} (!= b 0)
    §R (/ a b)

