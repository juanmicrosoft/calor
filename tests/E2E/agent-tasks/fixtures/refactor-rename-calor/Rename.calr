§M{m001:RenameExamples}
  §F{f001:Calculate:pub} (i32:val) -> i32
    §S (== result (* val 2))
    §R (* val 2)

  §F{f002:ValidatedOp:pub} (i32:num, i32:max) -> i32
    §Q (>= num 0)
    §Q (<= num max)
    §S (<= result max)
    §R num

  §F{f003:OuterCalc:pub} (i32:x) -> i32
    §B{inner} (* x 2)
    §R (+ x inner)

