§M{m001:GridOps}

§F{f001:SumGrid:pub}
  §I{i32:size}
  §O{i32}
  §B{~total} INT:0
  §L{l1:x:0:size:1}
    §B{plane} §C{SumPlane} §A x §A size §/C
    §B{~total} (+ total plane)
  §/L{l1}
  §R total
§/F{f001}

§F{f002:SumPlane:pub}
  §I{i32:x}
  §I{i32:size}
  §O{i32}
  §B{~sum} INT:0
  §L{l2:y:0:size:1}
    §L{l3:z:0:size:1}
      §B{~sum} (+ sum (+ x (+ y z)))
    §/L{l3}
  §/L{l2}
  §R sum
§/F{f002}

§/M{m001}
