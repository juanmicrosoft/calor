§M{m001:MathOps}

§F{f001:Calculate:pub}
  §I{i32:val}
  §I{i32:prior}
  §O{i32}
  §Q (>= val 0)
  §S (>= result prior)
  §B{validated} §C{ValidateInput} §A val §/C
  §B{scaled} §C{ScaleInput} §A validated §/C
  §B{total} §C{RunningTotal} §A scaled §A prior §/C
  §R total
§/F{f001}

§F{f002:ValidateInput:pub}
  §I{i32:val}
  §O{i32}
  §Q (>= val 0)
  §R val
§/F{f002}

§F{f003:ScaleInput:pub}
  §I{i32:val}
  §O{i32}
  §R (* val 2)
§/F{f003}

§F{f004:RunningTotal:pub}
  §I{i32:scaled}
  §I{i32:prior}
  §O{i32}
  §R (+ scaled prior)
§/F{f004}

§/M{m001}
