§M{m001:Scoring}

§F{f001:ClampScore:pub}
  §I{i32:score}
  §I{i32:max}
  §O{i32}
  §Q (>= max 0)
  §S (<= result max)
  §IF{i1} (> score max) → §R max
  §R score
§/F{f001}

§F{f002:ClampLowerBound:pub}
  §I{i32:val}
  §O{i32}
  §S (>= result 0)
  §IF{i2} (< val 0) → §R 0
  §R val
§/F{f002}

§/M{m001}
