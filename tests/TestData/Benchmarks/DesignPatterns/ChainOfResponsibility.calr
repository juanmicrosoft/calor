§M{m001:ChainOfResponsibility}
  §F{f001:CanApprove:pub} (f32:amount, f32:limit) -> bool
    §Q (> amount 0)
    §Q (> limit 0)
    §R (<= amount limit)

  §F{f002:ManagerLimit:pub} () -> f32
    §R 1000

  §F{f003:DirectorLimit:pub} () -> f32
    §R 10000

  §F{f004:VPLimit:pub} () -> f32
    §R 100000

