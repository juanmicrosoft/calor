§M{m001:StateMachine}
  §F{f001:NextState:pub} (i32:current) -> i32
    §IF{if1} (== current 0)
      §R 1
    §EI (== current 1)
      §R 2
    §EL
      §R 0

  §F{f002:IsGreen:pub} (i32:state) -> bool
    §R (== state 0)

  §F{f003:IsYellow:pub} (i32:state) -> bool
    §R (== state 1)

  §F{f004:IsRed:pub} (i32:state) -> bool
    §R (== state 2)

