§M{m001:Flyweight}
  §F{f001:PoolSize:pub} (i32:uniqueCount) -> i32
    §S (>= result 0)
    §R uniqueCount

  §F{f002:MemorySaved:pub} (i32:totalObjects, i32:uniqueObjects, i32:objectSize) -> i32
    §Q (>= totalObjects uniqueObjects)
    §S (>= result 0)
    §R (* (- totalObjects uniqueObjects) objectSize)

  §F{f003:IsPooled:pub} (i32:objectId, i32:poolSize) -> bool
    §R (< objectId poolSize)

