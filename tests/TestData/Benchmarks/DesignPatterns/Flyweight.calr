§M{m001:Flyweight}
§F{f001:PoolSize:pub}
  §I{i32:uniqueCount}
  §O{i32}
  §S (>= result 0)
  §R uniqueCount
§/F{f001}
§F{f002:MemorySaved:pub}
  §I{i32:totalObjects}
  §I{i32:uniqueObjects}
  §I{i32:objectSize}
  §O{i32}
  §Q (>= totalObjects uniqueObjects)
  §S (>= result 0)
  §R (* (- totalObjects uniqueObjects) objectSize)
§/F{f002}
§F{f003:IsPooled:pub}
  §I{i32:objectId}
  §I{i32:poolSize}
  §O{bool}
  §R (< objectId poolSize)
§/F{f003}
§/M{m001}
