§M{m001:ShapeFactory}
  §F{f001:CircleArea:pub} (f32:radius) -> f32
    §Q (> radius 0)
    §S (>= result 0)
    §R (* 3.14159 (* radius radius))

  §F{f002:RectangleArea:pub} (f32:width, f32:height) -> f32
    §Q (> width 0)
    §Q (> height 0)
    §S (>= result 0)
    §R (* width height)

  §F{f003:SquareArea:pub} (f32:side) -> f32
    §Q (> side 0)
    §S (>= result 0)
    §R (* side side)

  §F{f004:CirclePerimeter:pub} (f32:radius) -> f32
    §Q (> radius 0)
    §S (>= result 0)
    §R (* 2 (* 3.14159 radius))

  §F{f005:RectanglePerimeter:pub} (f32:width, f32:height) -> f32
    §Q (> width 0)
    §Q (> height 0)
    §S (>= result 0)
    §R (* 2 (+ width height))

