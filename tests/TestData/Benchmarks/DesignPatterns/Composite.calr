§M{m001:Composite}
  §F{f001:FileSize:pub} (i32:size) -> i32
    §Q (>= size 0)
    §R size

  §F{f002:TotalSize:pub} (i32:ownSize, i32:childrenSize) -> i32
    §S (>= result ownSize)
    §R (+ ownSize childrenSize)

  §F{f003:IsLeaf:pub} (i32:childCount) -> bool
    §R (== childCount 0)

