§M{m001:DesignPatterns}
  §IFACE{i001:IExpressionVisitor}
    §MT{m001:VisitNumber} (NumberExpression:expr) -> f32
    §MT{m002:VisitAdd} (AddExpression:expr) -> f32
    §MT{m003:VisitMultiply} (MultiplyExpression:expr) -> f32

  §CL{c001:Expression:int:abs}
    §MT{mt001:Accept:priv} (IExpressionVisitor:visitor) -> f32
      §R


  §CL{c002:NumberExpression:pub}
    §EXT{Expression}

    §FLD{f64:Value:pub}

    §CTOR{ctor001:pub} (f32:value)
      §ASSIGN this.Value value

    §MT{mt001:Accept:pub:over} (IExpressionVisitor:visitor) -> f32
      §R §C{visitor.VisitNumber} §THIS


  §CL{c003:AddExpression:pub}
    §EXT{Expression}

    §FLD{Expression:Left:pub}
    §FLD{Expression:Right:pub}

    §CTOR{ctor001:pub} (Expression:left, Expression:right)
      §ASSIGN this.Left left
      §ASSIGN this.Right right

    §MT{mt001:Accept:pub:over} (IExpressionVisitor:visitor) -> f32
      §R §C{visitor.VisitAdd} §THIS


  §CL{c004:MultiplyExpression:pub}
    §EXT{Expression}

    §FLD{Expression:Left:pub}
    §FLD{Expression:Right:pub}

    §CTOR{ctor001:pub} (Expression:left, Expression:right)
      §ASSIGN this.Left left
      §ASSIGN this.Right right

    §MT{mt001:Accept:pub:over} (IExpressionVisitor:visitor) -> f32
      §R §C{visitor.VisitMultiply} §THIS


  §CL{c005:EvaluatorVisitor:pub}
    §IMPL{IExpressionVisitor}

    §MT{mt001:VisitNumber:pub} (NumberExpression:expr) -> f32
      §R expr.Value

    §MT{mt002:VisitAdd:pub} (AddExpression:expr) -> f32
      §B{~_hoist000} §C{expr.Left.Accept} §THIS
      §B{~_hoist001} §C{expr.Right.Accept} §THIS
      §R (+ _hoist000 _hoist001)

    §MT{mt003:VisitMultiply:pub} (MultiplyExpression:expr) -> f32
      §B{~_hoist002} §C{expr.Left.Accept} §THIS
      §B{~_hoist003} §C{expr.Right.Accept} §THIS
      §R (* _hoist002 _hoist003)


  §CL{c006:VisitorDemo:int:stat}
    §MT{mt001:Evaluate:pub:stat} (Expression:expr) -> f32
      §B{EvaluatorVisitor:visitor} §NEW{EvaluatorVisitor} §/NEW
      §R §C{expr.Accept} visitor

    §MT{mt002:BuildSampleExpression:pub:stat} () -> Expression
      §B{NumberExpression:two} §NEW{NumberExpression} §A 2 §/NEW
      §B{NumberExpression:three} §NEW{NumberExpression} §A 3 §/NEW
      §B{NumberExpression:four} §NEW{NumberExpression} §A 4 §/NEW
      §B{AddExpression:sum} §NEW{AddExpression} §A two §A three §/NEW
      §R §NEW{MultiplyExpression} §A sum §A four §/NEW


