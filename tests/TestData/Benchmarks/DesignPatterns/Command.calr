§M{m001:Command}
  §F{f001:Execute:pub} (i32:value, i32:delta) -> i32
    §R (+ value delta)

  §F{f002:Undo:pub} (i32:value, i32:delta) -> i32
    §R (- value delta)

  §F{f003:CanUndo:pub} (i32:historySize) -> bool
    §R (> historySize 0)

  §F{f004:HistoryPush:pub} (i32:historySize) -> i32
    §R (+ historySize 1)

