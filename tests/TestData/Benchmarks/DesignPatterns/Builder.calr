§M{m001:Builder}
  §F{f001:IsComplete:pub} (bool:hasName, bool:hasAge) -> bool
    §R (&& hasName hasAge)

  §F{f002:SetStep:pub} (i32:currentStep) -> i32
    §R (+ currentStep 1)

  §F{f003:CanBuild:pub} (i32:requiredSteps, i32:completedSteps) -> bool
    §R (>= completedSteps requiredSteps)

