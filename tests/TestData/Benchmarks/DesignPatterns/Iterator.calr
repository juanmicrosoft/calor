§M{m001:Iterator}
  §F{f001:HasNext:pub} (i32:current, i32:end) -> bool
    §R (< current end)

  §F{f002:Next:pub} (i32:current, i32:step) -> i32
    §Q (> step 0)
    §R (+ current step)

  §F{f003:Current:pub} (i32:value) -> i32
    §R value

  §F{f004:Reset:pub} (i32:start) -> i32
    §R start

