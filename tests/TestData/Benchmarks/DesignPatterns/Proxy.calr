§M{m001:Proxy}
  §F{f001:HasAccess:pub} (i32:userRole, i32:requiredRole) -> bool
    §R (>= userRole requiredRole)

  §F{f002:LogAccess:pub} (i32:userId, bool:granted) -> i32
    §E{cw}
    §IF{if1} granted
      §P "Access granted"
    §EL
      §P "Access denied"
    §R userId

  §F{f003:CacheHit:pub} (bool:isCached) -> bool
    §R isCached

