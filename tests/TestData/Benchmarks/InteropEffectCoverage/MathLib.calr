§M{m001:MathLib}
  §F{f001:Square:pub} (f32:x) -> f32
    §S (>= result 0)
    §R (* x x)

  §F{f002:Cube:pub} (f32:x) -> f32
    §R (* x (* x x))

  §F{f003:MaxOf:pub} (f32:a, f32:b) -> f32
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

  §F{f004:Floor:pub} (f32:x) -> i32
    §R (cast i32 x)

