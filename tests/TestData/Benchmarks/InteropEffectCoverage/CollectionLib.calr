§M{m001:CollectionLib}
§F{f001:ListLength:pub}
  §I{i32:count}
  §O{i32}
  §S (>= result 0)
  §R count
§/F{f001}
§F{f002:IsInBounds:pub}
  §I{i32:index}
  §I{i32:count}
  §O{bool}
  §R (&& (>= index 0) (< index count))
§/F{f002}
§F{f003:AfterAdd:pub}
  §I{i32:count}
  §O{i32}
  §S (> result count)
  §R (+ count 1)
§/F{f003}
§/M{m001}
