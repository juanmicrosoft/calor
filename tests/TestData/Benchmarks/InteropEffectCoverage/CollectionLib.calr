§M{m001:CollectionLib}
  §F{f001:ListLength:pub} (i32:count) -> i32
    §S (>= result 0)
    §R count

  §F{f002:IsInBounds:pub} (i32:index, i32:count) -> bool
    §R (&& (>= index 0) (< index count))

  §F{f003:AfterAdd:pub} (i32:count) -> i32
    §S (> result count)
    §R (+ count 1)

