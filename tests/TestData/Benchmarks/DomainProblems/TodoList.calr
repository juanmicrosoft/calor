§M{m001:TodoList}
  §F{f001:AddTask:pub} (i32:count) -> i32
    §R (+ count 1)

  §F{f002:CompleteTask:pub} (i32:completedCount) -> i32
    §R (+ completedCount 1)

  §F{f003:PendingCount:pub} (i32:total, i32:completed) -> i32
    §Q (>= total completed)
    §S (>= result 0)
    §R (- total completed)

  §F{f004:AllDone:pub} (i32:total, i32:completed) -> bool
    §R (== total completed)

