§M{m001:CurrencyConverter}
§F{f001:Convert:pub}
  §I{f64:amount}
  §I{f64:rate}
  §O{f64}
  §Q (>= amount 0.0)
  §Q (> rate 0.0)
  §S (>= result 0.0)
  §R (* amount rate)
§/F{f001}
§F{f002:RoundToTwo:pub}
  §I{f64:value}
  §O{f64}
  §B{shifted} (* value 100.0)
  §R (/ (cast f64 (cast i32 (+ shifted 0.5))) 100.0)
§/F{f002}
§F{f003:InverseRate:pub}
  §I{f64:rate}
  §O{f64}
  §Q (> rate 0.0)
  §R (/ 1.0 rate)
§/F{f003}
§/M{m001}
