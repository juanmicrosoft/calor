§M{m001:UnitConverter}
  §F{f001:InchesToCm:pub} (f32:inches) -> f32
    §Q (>= inches 0)
    §R (* inches 2.54)

  §F{f002:CmToInches:pub} (f32:cm) -> f32
    §Q (>= cm 0)
    §R (/ cm 2.54)

  §F{f003:PoundsToKg:pub} (f32:pounds) -> f32
    §Q (>= pounds 0)
    §R (* pounds 0.453592)

  §F{f004:KgToPounds:pub} (f32:kg) -> f32
    §Q (>= kg 0)
    §R (/ kg 0.453592)

  §F{f005:GallonsToLiters:pub} (f32:gallons) -> f32
    §Q (>= gallons 0)
    §R (* gallons 3.78541)

