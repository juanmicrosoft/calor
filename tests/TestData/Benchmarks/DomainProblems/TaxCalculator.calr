§M{m001:TaxCalculator}
§F{f001:TaxRate:pub}
  §I{f64:income}
  §O{f64}
  §Q (>= income 0.0)
  §IF{if1} (<= income 10000.0) → §R 0.1
  §EI (<= income 40000.0) → §R 0.2
  §EI (<= income 85000.0) → §R 0.3
  §EL → §R 0.37
  §/I{if1}
§/F{f001}
§F{f002:SimpleTax:pub}
  §I{f64:income}
  §I{f64:rate}
  §O{f64}
  §Q (>= income 0.0)
  §Q (>= rate 0.0)
  §Q (<= rate 1.0)
  §R (* income rate)
§/F{f002}
§F{f003:AfterTax:pub}
  §I{f64:income}
  §I{f64:tax}
  §O{f64}
  §Q (>= income 0.0)
  §Q (>= tax 0.0)
  §S (>= result 0.0)
  §R (- income tax)
§/F{f003}
§/M{m001}
