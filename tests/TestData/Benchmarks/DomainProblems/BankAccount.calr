§M{m001:BankAccount}
  §F{f001:Deposit:pub} (f32:balance, f32:amount) -> f32
    §Q (> amount 0)
    §S (> result balance)
    §R (+ balance amount)

  §F{f002:Withdraw:pub} (f32:balance, f32:amount) -> f32
    §Q (> amount 0)
    §Q (>= balance amount)
    §S (< result balance)
    §R (- balance amount)

  §F{f003:CanWithdraw:pub} (f32:balance, f32:amount) -> bool
    §R (&& (> amount 0) (>= balance amount))

