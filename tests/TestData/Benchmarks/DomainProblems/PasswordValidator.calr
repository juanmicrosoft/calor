§M{m001:PasswordValidator}
  §F{f001:LongEnough:pub} (i32:length, i32:minLength) -> bool
    §R (>= length minLength)

  §F{f002:HasDigit:pub} (bool:containsDigit) -> bool
    §R containsDigit

  §F{f003:HasUpper:pub} (bool:containsUpper) -> bool
    §R containsUpper

  §F{f004:StrengthScore:pub} (bool:longEnough, bool:hasDigit, bool:hasUpper, bool:hasSpecial) -> i32
    §B{score} 0
    §IF{if1} longEnough
      §ASSIGN score (+ score 1)
    §IF{if2} hasDigit
      §ASSIGN score (+ score 1)
    §IF{if3} hasUpper
      §ASSIGN score (+ score 1)
    §IF{if4} hasSpecial
      §ASSIGN score (+ score 1)
    §R score

