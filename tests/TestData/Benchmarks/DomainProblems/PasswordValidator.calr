§M{m001:PasswordValidator}
§F{f001:LongEnough:pub}
  §I{i32:length}
  §I{i32:minLength}
  §O{bool}
  §R (>= length minLength)
§/F{f001}
§F{f002:HasDigit:pub}
  §I{bool:containsDigit}
  §O{bool}
  §R containsDigit
§/F{f002}
§F{f003:HasUpper:pub}
  §I{bool:containsUpper}
  §O{bool}
  §R containsUpper
§/F{f003}
§F{f004:StrengthScore:pub}
  §I{bool:longEnough}
  §I{bool:hasDigit}
  §I{bool:hasUpper}
  §I{bool:hasSpecial}
  §O{i32}
  §B{score} 0
  §IF{if1} longEnough → §ASSIGN score (+ score 1)
  §/I{if1}
  §IF{if2} hasDigit → §ASSIGN score (+ score 1)
  §/I{if2}
  §IF{if3} hasUpper → §ASSIGN score (+ score 1)
  §/I{if3}
  §IF{if4} hasSpecial → §ASSIGN score (+ score 1)
  §/I{if4}
  §R score
§/F{f004}
§/M{m001}
