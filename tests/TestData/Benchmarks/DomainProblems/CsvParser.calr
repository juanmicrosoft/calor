§M{m001:CsvParser}
  §F{f001:FieldCount:pub} (i32:commaCount) -> i32
    §S (> result 0)
    §R (+ commaCount 1)

  §F{f002:IsQuoted:pub} (i32:firstChar) -> bool
    §R (== firstChar 34)

  §F{f003:IsDelimiter:pub} (i32:charCode) -> bool
    §R (== charCode 44)

  §F{f004:IsNewline:pub} (i32:charCode) -> bool
    §R (|| (== charCode 10) (== charCode 13))

