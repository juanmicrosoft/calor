§M{m001:Inventory}
  §F{f001:Restock:pub} (i32:current, i32:quantity) -> i32
    §Q (> quantity 0)
    §S (> result current)
    §R (+ current quantity)

  §F{f002:Sell:pub} (i32:current, i32:quantity) -> i32
    §Q (> quantity 0)
    §Q (>= current quantity)
    §S (>= result 0)
    §R (- current quantity)

  §F{f003:InStock:pub} (i32:quantity) -> bool
    §R (> quantity 0)

  §F{f004:NeedsReorder:pub} (i32:quantity, i32:threshold) -> bool
    §R (<= quantity threshold)

