§M{m001:BMICalculator}
§F{f001:CalculateBMI:pub}
  §I{f64:weightKg}
  §I{f64:heightM}
  §O{f64}
  §Q (> weightKg 0.0)
  §Q (> heightM 0.0)
  §S (> result 0.0)
  §R (/ weightKg (* heightM heightM))
§/F{f001}
§F{f002:Category:pub}
  §I{f64:bmi}
  §O{i32}
  §Q (> bmi 0.0)
  §IF{if1} (< bmi 18.5) → §R 0
  §EI (< bmi 25.0) → §R 1
  §EI (< bmi 30.0) → §R 2
  §EL → §R 3
  §/I{if1}
§/F{f002}
§F{f003:IsHealthy:pub}
  §I{f64:bmi}
  §O{bool}
  §R (&& (>= bmi 18.5) (< bmi 25.0))
§/F{f003}
§/M{m001}
