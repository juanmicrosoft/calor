§M{m001:DistanceCalculator}
  §F{f001:DistanceSquared:pub} (f32:x1, f32:y1, f32:x2, f32:y2) -> f32
    §S (>= result 0)
    §B{dx} (- x2 x1)
    §B{dy} (- y2 y1)
    §R (+ (* dx dx) (* dy dy))

  §F{f002:ManhattanDist:pub} (f32:x1, f32:y1, f32:x2, f32:y2) -> f32
    §S (>= result 0)
    §B{dx} (- x2 x1)
    §B{dy} (- y2 y1)
    §B{absDx} dx
    §IF{if1} (< absDx 0)
      §ASSIGN absDx (- 0 absDx)
    §B{absDy} dy
    §IF{if2} (< absDy 0)
      §ASSIGN absDy (- 0 absDy)
    §R (+ absDx absDy)

