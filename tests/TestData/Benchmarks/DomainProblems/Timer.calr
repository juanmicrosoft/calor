§M{m001:Timer}
  §F{f001:SecondsToMinutes:pub} (i32:seconds) -> i32
    §Q (>= seconds 0)
    §R (/ seconds 60)

  §F{f002:RemainingSeconds:pub} (i32:seconds) -> i32
    §Q (>= seconds 0)
    §R (% seconds 60)

  §F{f003:IsExpired:pub} (i32:remaining) -> bool
    §R (<= remaining 0)

  §F{f004:Tick:pub} (i32:remaining) -> i32
    §Q (> remaining 0)
    §S (< result remaining)
    §R (- remaining 1)

