§M{m001:UrlParser}
  §F{f001:HasProtocol:pub} (bool:startsWithHttp) -> bool
    §R startsWithHttp

  §F{f002:IsSecure:pub} (bool:isHttps) -> bool
    §R isHttps

  §F{f003:DefaultPort:pub} (bool:isHttps) -> i32
    §IF{if1} isHttps
      §R 443
    §EL
      §R 80

  §F{f004:IsValidPort:pub} (i32:port) -> bool
    §R (&& (> port 0) (<= port 65535))

