§M{m001:DateDiff}
§F{f001:DaysBetween:pub}
  §I{i32:dayA}
  §I{i32:dayB}
  §O{i32}
  §S (>= result 0)
  §B{diff} (- dayB dayA)
  §IF{if1} (< diff 0) → §R (- 0 diff)
  §EL → §R diff
  §/I{if1}
§/F{f001}
§F{f002:WeeksBetween:pub}
  §I{i32:days}
  §O{i32}
  §Q (>= days 0)
  §R (/ days 7)
§/F{f002}
§F{f003:RemainingDays:pub}
  §I{i32:days}
  §O{i32}
  §Q (>= days 0)
  §R (% days 7)
§/F{f003}
§/M{m001}
