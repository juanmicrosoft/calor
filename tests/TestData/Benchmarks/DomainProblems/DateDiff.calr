§M{m001:DateDiff}
  §F{f001:DaysBetween:pub} (i32:dayA, i32:dayB) -> i32
    §S (>= result 0)
    §B{diff} (- dayB dayA)
    §IF{if1} (< diff 0)
      §R (- 0 diff)
    §EL
      §R diff

  §F{f002:WeeksBetween:pub} (i32:days) -> i32
    §Q (>= days 0)
    §R (/ days 7)

  §F{f003:RemainingDays:pub} (i32:days) -> i32
    §Q (>= days 0)
    §R (% days 7)

