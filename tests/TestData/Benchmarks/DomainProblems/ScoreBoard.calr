§M{m001:ScoreBoard}
  §F{f001:UpdateScore:pub} (i32:current, i32:points) -> i32
    §R (+ current points)

  §F{f002:IsHighScore:pub} (i32:score, i32:highScore) -> bool
    §R (> score highScore)

  §F{f003:Rank:pub} (i32:winsAbove) -> i32
    §S (>= result 1)
    §R (+ winsAbove 1)

  §F{f004:AverageScore:pub} (i32:totalScore, i32:games) -> f32
    §Q (> games 0)
    §R (/ (cast f64 totalScore) (cast f64 games))

