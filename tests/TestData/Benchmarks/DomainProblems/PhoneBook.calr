§M{m001:PhoneBook}
  §F{f001:EntryCount:pub} (i32:count) -> i32
    §S (>= result 0)
    §R count

  §F{f002:AddEntry:pub} (i32:count) -> i32
    §R (+ count 1)

  §F{f003:RemoveEntry:pub} (i32:count) -> i32
    §Q (> count 0)
    §S (>= result 0)
    §R (- count 1)

  §F{f004:IsEmpty:pub} (i32:count) -> bool
    §R (== count 0)

