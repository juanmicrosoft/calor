§M{m001:EmailValidator}
  §F{f001:HasAtSign:pub} (bool:containsAt) -> bool
    §R containsAt

  §F{f002:HasDot:pub} (bool:containsDot) -> bool
    §R containsDot

  §F{f003:IsValidLength:pub} (i32:length) -> bool
    §R (&& (>= length 5) (<= length 254))

  §F{f004:IsValid:pub} (bool:hasAt, bool:hasDot, i32:length) -> bool
    §R (&& (&& hasAt hasDot) (&& (>= length 5) (<= length 254)))

