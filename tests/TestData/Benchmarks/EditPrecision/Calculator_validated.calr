§M{m001:Calculator}
  §F{f001:Add:pub} (i32:a, i32:b) -> i32
    §Q (>= a 0)
    §Q (>= b 0)
    §R (+ a b)

  §F{f002:Subtract:pub} (i32:a, i32:b) -> i32
    §Q (>= a 0)
    §Q (>= b 0)
    §R (- a b)

  §F{f003:Multiply:pub} (i32:a, i32:b) -> i32
    §Q (>= a 0)
    §Q (>= b 0)
    §R (* a b)

  §F{f004:Divide:pub} (i32:a, i32:b) -> i32
    §Q (>= a 0)
    §Q (> b 0)
    §R (/ a b)

