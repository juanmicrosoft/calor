§M{m001:Dijkstra}
§F{f001:Relax:pub}
  §I{i32:currentDist}
  §I{i32:edgeWeight}
  §I{i32:neighborDist}
  §O{bool}
  §Q (>= currentDist 0)
  §Q (> edgeWeight 0)
  §R (< (+ currentDist edgeWeight) neighborDist)
§/F{f001}
§F{f002:NewDist:pub}
  §I{i32:currentDist}
  §I{i32:edgeWeight}
  §O{i32}
  §Q (>= currentDist 0)
  §Q (> edgeWeight 0)
  §S (> result currentDist)
  §R (+ currentDist edgeWeight)
§/F{f002}
§F{f003:Infinity:pub}
  §O{i32}
  §R 2147483647
§/F{f003}
§/M{m001}
