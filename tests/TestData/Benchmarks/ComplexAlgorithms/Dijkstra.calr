§M{m001:Dijkstra}
  §F{f001:Relax:pub} (i32:currentDist, i32:edgeWeight, i32:neighborDist) -> bool
    §Q (>= currentDist 0)
    §Q (> edgeWeight 0)
    §R (< (+ currentDist edgeWeight) neighborDist)

  §F{f002:NewDist:pub} (i32:currentDist, i32:edgeWeight) -> i32
    §Q (>= currentDist 0)
    §Q (> edgeWeight 0)
    §S (> result currentDist)
    §R (+ currentDist edgeWeight)

  §F{f003:Infinity:pub} () -> i32
    §R 2147483647

