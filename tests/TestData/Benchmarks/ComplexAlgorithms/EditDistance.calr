§M{m001:EditDistance}
  §F{f001:MinOfThree:pub} (i32:a, i32:b, i32:c) -> i32
    §B{minAB} a
    §IF{if1} (< b minAB)
      §ASSIGN minAB b
    §IF{if2} (< c minAB)
      §R c
    §EL
      §R minAB

  §F{f002:SubstitutionCost:pub} (i32:charA, i32:charB) -> i32
    §IF{if1} (== charA charB)
      §R 0
    §EL
      §R 1

