§M{m001:MergeSort}
  §F{f001:MidPoint:pub} (i32:low, i32:high) -> i32
    §Q (<= low high)
    §R (+ low (/ (- high low) 2))

  §F{f002:ShouldTakeLeft:pub} (i32:leftVal, i32:rightVal) -> bool
    §R (<= leftVal rightVal)

  §F{f003:IsBaseCase:pub} (i32:low, i32:high) -> bool
    §R (>= low high)

