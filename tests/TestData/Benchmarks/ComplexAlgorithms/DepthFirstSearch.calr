§M{m001:DepthFirstSearch}
  §F{f001:IsVisited:pub} (i32:node, i32:visitedBitmask) -> bool
    §R (!= visitedBitmask 0)

  §F{f002:MarkVisited:pub} (i32:visitedCount) -> i32
    §R (+ visitedCount 1)

  §F{f003:AllVisited:pub} (i32:visitedCount, i32:totalNodes) -> bool
    §R (== visitedCount totalNodes)

