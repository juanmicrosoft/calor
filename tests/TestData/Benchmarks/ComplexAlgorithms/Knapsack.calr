§M{m001:Knapsack}
  §F{f001:BetterValue:pub} (i32:withItem, i32:withoutItem) -> i32
    §IF{if1} (> withItem withoutItem)
      §R withItem
    §EL
      §R withoutItem

  §F{f002:Fits:pub} (i32:weight, i32:capacity) -> bool
    §Q (> weight 0)
    §Q (>= capacity 0)
    §R (<= weight capacity)

  §F{f003:RemainingCapacity:pub} (i32:capacity, i32:weight) -> i32
    §Q (>= capacity weight)
    §S (>= result 0)
    §R (- capacity weight)

