§M{m001:QuickSort}
  §F{f001:ChoosePivot:pub} (i32:low, i32:high) -> i32
    §Q (>= low 0)
    §Q (<= low high)
    §R high

  §F{f002:ShouldSwap:pub} (i32:value, i32:pivot) -> bool
    §R (<= value pivot)

  §F{f003:NextPartitionIndex:pub} (i32:current) -> i32
    §R (+ current 1)

  §F{f004:IsSortedPair:pub} (i32:a, i32:b) -> bool
    §R (<= a b)

