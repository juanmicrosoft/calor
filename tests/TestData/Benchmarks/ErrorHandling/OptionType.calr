§M{m001:OptionType}
  §F{f001:HasValue:pub} (bool:isSome) -> bool
    §R isSome

  §F{f002:Unwrap:pub} (i32:value, bool:isSome) -> i32
    §Q (== isSome true)
    §R value

  §F{f003:GetOrElse:pub} (i32:value, i32:fallback, bool:isSome) -> i32
    §IF{if1} isSome
      §R value
    §EL
      §R fallback

