§M{m001:GuardClause}
  §F{f001:ValidatePositive:pub} (i32:value) -> bool
    §R (> value 0)

  §F{f002:ValidateRange:pub} (i32:value, i32:min, i32:max) -> bool
    §Q (<= min max)
    §R (&& (>= value min) (<= value max))

  §F{f003:ValidateNotEmpty:pub} (i32:length) -> bool
    §R (> length 0)

