§M{m001:GuardClause}
§F{f001:ValidatePositive:pub}
  §I{i32:value}
  §O{bool}
  §R (> value 0)
§/F{f001}
§F{f002:ValidateRange:pub}
  §I{i32:value}
  §I{i32:min}
  §I{i32:max}
  §O{bool}
  §Q (<= min max)
  §R (&& (>= value min) (<= value max))
§/F{f002}
§F{f003:ValidateNotEmpty:pub}
  §I{i32:length}
  §O{bool}
  §R (> length 0)
§/F{f003}
§/M{m001}
