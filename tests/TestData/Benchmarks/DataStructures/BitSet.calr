§M{m001:BitSet}
  §F{f001:PowerOfTwo:pub} (i32:pos) -> i32
    §Q (>= pos 0)
    §Q (< pos 32)
    §S (> result 0)
    §IF{if1} (== pos 0)
      §R 1
    §B{sub} §C{PowerOfTwo} §A (- pos 1) §/C
    §R (* 2 sub)

  §F{f002:SetBit:pub} (i32:bits, i32:pos) -> i32
    §Q (>= pos 0)
    §Q (< pos 32)
    §B{mask} §C{PowerOfTwo} §A pos §/C
    §R (+ bits mask)

  §F{f003:TestBit:pub} (i32:bits, i32:pos) -> bool
    §Q (>= pos 0)
    §Q (< pos 32)
    §B{mask} §C{PowerOfTwo} §A pos §/C
    §B{div} (/ bits mask)
    §R (!= (% div 2) 0)

  §F{f004:PopCount:pub} (i32:bits) -> i32
    §S (>= result 0)
    §IF{if1} (== bits 0)
      §R 0
    §B{rest} §C{PopCount} §A (/ bits 2) §/C
    §R (+ (% bits 2) rest)

