§M{m001:BinaryTree}
  §F{f001:CompareValues:pub} (i32:a, i32:b) -> i32
    §IF{if1} (< a b)
      §R -1
    §EI (> a b)
      §R 1
    §EL
      §R 0

  §F{f002:ShouldGoLeft:pub} (i32:value, i32:nodeValue) -> bool
    §R (< value nodeValue)

  §F{f003:ShouldGoRight:pub} (i32:value, i32:nodeValue) -> bool
    §R (> value nodeValue)

  §F{f004:IsMatch:pub} (i32:value, i32:nodeValue) -> bool
    §R (== value nodeValue)

