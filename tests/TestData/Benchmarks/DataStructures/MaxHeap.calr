§M{m001:MaxHeap}
  §F{f001:Parent:pub} (i32:index) -> i32
    §Q (> index 0)
    §R (/ (- index 1) 2)

  §F{f002:LeftChild:pub} (i32:index) -> i32
    §R (+ (* 2 index) 1)

  §F{f003:RightChild:pub} (i32:index) -> i32
    §R (+ (* 2 index) 2)

  §F{f004:ShouldSwapUp:pub} (i32:child, i32:parent) -> bool
    §R (> child parent)

  §F{f005:HasChild:pub} (i32:childIndex, i32:size) -> bool
    §R (< childIndex size)

