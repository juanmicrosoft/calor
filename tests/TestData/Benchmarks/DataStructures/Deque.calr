§M{m001:Deque}
  §F{f001:CanRemove:pub} (i32:size) -> bool
    §R (> size 0)

  §F{f002:NewSizeAfterAdd:pub} (i32:size) -> i32
    §S (> result size)
    §R (+ size 1)

  §F{f003:NewSizeAfterRemove:pub} (i32:size) -> i32
    §Q (> size 0)
    §S (< result size)
    §R (- size 1)

  §F{f004:IsEmpty:pub} (i32:size) -> bool
    §R (== size 0)

