§M{m001:DisjointSet}
  §F{f001:IsRoot:pub} (i32:node, i32:parent) -> bool
    §R (== node parent)

  §F{f002:ShouldMerge:pub} (i32:rootA, i32:rootB) -> bool
    §R (!= rootA rootB)

  §F{f003:PickRoot:pub} (i32:rankA, i32:rankB, i32:rootA, i32:rootB) -> i32
    §IF{if1} (>= rankA rankB)
      §R rootA
    §EL
      §R rootB

