§M{m001:HashMap}
  §F{f001:BucketIndex:pub} (i32:hashCode, i32:bucketCount) -> i32
    §Q (> bucketCount 0)
    §S (>= result 0)
    §S (< result bucketCount)
    §B{absHash} hashCode
    §IF{if1} (< absHash 0)
      §ASSIGN absHash (- 0 absHash)
    §R (% absHash bucketCount)

  §F{f002:LoadFactor:pub} (i32:itemCount, i32:bucketCount) -> f32
    §Q (> bucketCount 0)
    §R (/ (cast f64 itemCount) (cast f64 bucketCount))

  §F{f003:NeedsResize:pub} (i32:itemCount, i32:bucketCount) -> bool
    §Q (> bucketCount 0)
    §R (> (* itemCount 100) (* bucketCount 75))

