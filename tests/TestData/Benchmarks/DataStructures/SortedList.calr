§M{m001:SortedList}
  §F{f001:FindInsertPos:pub} (i32:value, i32:existingValue) -> bool
    §R (<= value existingValue)

  §F{f002:IsInOrder:pub} (i32:a, i32:b) -> bool
    §R (<= a b)

  §F{f003:SizeAfterInsert:pub} (i32:currentSize) -> i32
    §S (> result currentSize)
    §R (+ currentSize 1)

