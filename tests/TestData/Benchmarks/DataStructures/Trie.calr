§M{m001:Trie}
  §F{f001:CharIndex:pub} (i32:charCode) -> i32
    §Q (>= charCode 97)
    §Q (<= charCode 122)
    §S (>= result 0)
    §S (< result 26)
    §R (- charCode 97)

  §F{f002:IsValidChar:pub} (i32:charCode) -> bool
    §R (&& (>= charCode 97) (<= charCode 122))

  §F{f003:IsEndOfWord:pub} (bool:flag) -> bool
    §R flag

  §F{f004:AlphabetSize:pub} () -> i32
    §R 26

