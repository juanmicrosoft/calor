§M{m001:CircularBuffer}
  §F{f001:NextIndex:pub} (i32:current, i32:capacity) -> i32
    §Q (> capacity 0)
    §S (>= result 0)
    §S (< result capacity)
    §R (% (+ current 1) capacity)

  §F{f002:IsFull:pub} (i32:count, i32:capacity) -> bool
    §R (== count capacity)

  §F{f003:IsEmpty:pub} (i32:count) -> bool
    §R (== count 0)

  §F{f004:WriteIndex:pub} (i32:head, i32:count, i32:capacity) -> i32
    §Q (> capacity 0)
    §R (% (+ head count) capacity)

