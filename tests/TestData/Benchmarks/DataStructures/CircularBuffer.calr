§M{m001:CircularBuffer}
§F{f001:NextIndex:pub}
  §I{i32:current}
  §I{i32:capacity}
  §O{i32}
  §Q (> capacity 0)
  §S (>= result 0)
  §S (< result capacity)
  §R (% (+ current 1) capacity)
§/F{f001}
§F{f002:IsFull:pub}
  §I{i32:count}
  §I{i32:capacity}
  §O{bool}
  §R (== count capacity)
§/F{f002}
§F{f003:IsEmpty:pub}
  §I{i32:count}
  §O{bool}
  §R (== count 0)
§/F{f003}
§F{f004:WriteIndex:pub}
  §I{i32:head}
  §I{i32:count}
  §I{i32:capacity}
  §O{i32}
  §Q (> capacity 0)
  §R (% (+ head count) capacity)
§/F{f004}
§/M{m001}
