§M{m001:PriorityQueue}
  §F{f001:HigherPriority:pub} (i32:a, i32:b) -> bool
    §R (< a b)

  §F{f002:ParentIndex:pub} (i32:index) -> i32
    §Q (> index 0)
    §R (/ (- index 1) 2)

  §F{f003:LeftChild:pub} (i32:index) -> i32
    §Q (>= index 0)
    §R (+ (* 2 index) 1)

  §F{f004:RightChild:pub} (i32:index) -> i32
    §Q (>= index 0)
    §R (+ (* 2 index) 2)

