§M{m001:PriorityQueue}
§F{f001:HigherPriority:pub}
  §I{i32:a}
  §I{i32:b}
  §O{bool}
  §R (< a b)
§/F{f001}
§F{f002:ParentIndex:pub}
  §I{i32:index}
  §O{i32}
  §Q (> index 0)
  §R (/ (- index 1) 2)
§/F{f002}
§F{f003:LeftChild:pub}
  §I{i32:index}
  §O{i32}
  §Q (>= index 0)
  §R (+ (* 2 index) 1)
§/F{f003}
§F{f004:RightChild:pub}
  §I{i32:index}
  §O{i32}
  §Q (>= index 0)
  §R (+ (* 2 index) 2)
§/F{f004}
§/M{m001}
