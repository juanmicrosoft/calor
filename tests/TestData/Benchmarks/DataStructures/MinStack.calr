§M{m001:MinStack}
  §F{f001:NewMin:pub} (i32:value, i32:currentMin) -> i32
    §IF{if1} (< value currentMin)
      §R value
    §EL
      §R currentMin

  §F{f002:IsNewMin:pub} (i32:value, i32:currentMin) -> bool
    §R (<= value currentMin)

  §F{f003:CanPop:pub} (i32:size) -> bool
    §R (> size 0)

