§M{m001:Capitalize}
  §F{f001:ShouldCapitalize:pub} (i32:charCode) -> bool
    §R (&& (>= charCode 97) (<= charCode 122))

  §F{f002:ToUpper:pub} (i32:charCode) -> i32
    §Q (&& (>= charCode 97) (<= charCode 122))
    §R (- charCode 32)

  §F{f003:IsEmpty:pub} (i32:length) -> bool
    §R (== length 0)

