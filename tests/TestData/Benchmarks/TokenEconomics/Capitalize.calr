§M{m001:Capitalize}
§F{f001:ShouldCapitalize:pub}
  §I{i32:charCode}
  §O{bool}
  §R (&& (>= charCode 97) (<= charCode 122))
§/F{f001}
§F{f002:ToUpper:pub}
  §I{i32:charCode}
  §O{i32}
  §Q (&& (>= charCode 97) (<= charCode 122))
  §R (- charCode 32)
§/F{f002}
§F{f003:IsEmpty:pub}
  §I{i32:length}
  §O{bool}
  §R (== length 0)
§/F{f003}
§/M{m001}
