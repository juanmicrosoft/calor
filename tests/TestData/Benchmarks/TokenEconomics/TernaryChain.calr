§M{m001:TernaryChain}
§F{f001:Classify:pub}
  §I{i32:score}
  §O{i32}
  §IF{if1} (>= score 90) → §R 4
  §EI (>= score 80) → §R 3
  §EI (>= score 70) → §R 2
  §EI (>= score 60) → §R 1
  §EL → §R 0
  §/I{if1}
§/F{f001}
§F{f002:Signum:pub}
  §I{i32:x}
  §O{i32}
  §IF{if1} (> x 0) → §R 1
  §EI (< x 0) → §R (- 0 1)
  §EL → §R 0
  §/I{if1}
§/F{f002}
§F{f003:Clamp100:pub}
  §I{i32:x}
  §O{i32}
  §IF{if1} (< x 0) → §R 0
  §EI (> x 100) → §R 100
  §EL → §R x
  §/I{if1}
§/F{f003}
§/M{m001}
