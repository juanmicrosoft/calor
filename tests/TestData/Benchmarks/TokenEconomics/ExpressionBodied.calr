§M{m001:ExpressionBodied}
  §F{f001:Double:pub} (i32:x) -> i32
    §R (* x 2)

  §F{f002:Triple:pub} (i32:x) -> i32
    §R (* x 3)

  §F{f003:Square:pub} (i32:x) -> i32
    §R (* x x)

  §F{f004:Increment:pub} (i32:x) -> i32
    §R (+ x 1)

  §F{f005:Decrement:pub} (i32:x) -> i32
    §R (- x 1)

  §F{f006:IsPositive:pub} (i32:x) -> bool
    §R (> x 0)

  §F{f007:IsNegative:pub} (i32:x) -> bool
    §R (< x 0)

  §F{f008:Negate:pub} (i32:x) -> i32
    §R (- 0 x)

