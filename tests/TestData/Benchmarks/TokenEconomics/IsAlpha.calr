§M{m001:IsAlpha}
  §F{f001:IsUpper:pub} (i32:charCode) -> bool
    §R (&& (>= charCode 65) (<= charCode 90))

  §F{f002:IsLower:pub} (i32:charCode) -> bool
    §R (&& (>= charCode 97) (<= charCode 122))

  §F{f003:IsAlpha:pub} (i32:charCode) -> bool
    §R (|| (&& (>= charCode 65) (<= charCode 90)) (&& (>= charCode 97) (<= charCode 122)))

