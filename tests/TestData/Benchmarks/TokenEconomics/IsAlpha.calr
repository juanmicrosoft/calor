§M{m001:IsAlpha}
§F{f001:IsUpper:pub}
  §I{i32:charCode}
  §O{bool}
  §R (&& (>= charCode 65) (<= charCode 90))
§/F{f001}
§F{f002:IsLower:pub}
  §I{i32:charCode}
  §O{bool}
  §R (&& (>= charCode 97) (<= charCode 122))
§/F{f002}
§F{f003:IsAlpha:pub}
  §I{i32:charCode}
  §O{bool}
  §R (|| (&& (>= charCode 65) (<= charCode 90)) (&& (>= charCode 97) (<= charCode 122)))
§/F{f003}
§/M{m001}
