§M{m001:DigitCount}
  §F{f001:IsZero:pub} (i32:n) -> bool
    §R (== n 0)

  §F{f002:Abs:pub} (i32:n) -> i32
    §S (>= result 0)
    §IF{if1} (< n 0)
      §R (- 0 n)
    §EL
      §R n

  §F{f003:DigitCountPositive:pub} (i32:n) -> i32
    §Q (>= n 0)
    §S (> result 0)
    §IF{if1} (< n 10)
      §R 1
    §B{rest} §C{DigitCountPositive} (/ n 10)
    §R (+ 1 rest)

  §F{f004:DigitCount:pub} (i32:n) -> i32
    §S (> result 0)
    §IF{if1} (== n 0)
      §R 1
    §B{absN} §C{Abs} n
    §R §C{DigitCountPositive} absN

