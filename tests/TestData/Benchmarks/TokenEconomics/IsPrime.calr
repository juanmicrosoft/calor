§M{m001:PrimeCheck}
  §F{f001:IsPrime:pub} (i32:n) -> bool
    §Q (> n 0)
    §IF{if1} (<= n 1)
      §R false
    §IF{if2} (<= n 3)
      §R true
    §IF{if3} (== (% n 2) 0)
      §R false
    §L{while1:i:3:1000:2}
      §IF{if4} (> (* i i) n)
        §R true
      §IF{if5} (== (% n i) 0)
        §R false
    §R true

