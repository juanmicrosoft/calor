§M{m001:SumDigits}
  §F{f001:LastDigit:pub} (i32:n) -> i32
    §S (>= result 0)
    §B{r} (% n 10)
    §IF{if1} (< r 0)
      §R (- 0 r)
    §EL
      §R r

  §F{f002:RemoveLastDigit:pub} (i32:n) -> i32
    §R (/ n 10)

  §F{f003:SumDigitsPositive:pub} (i32:n) -> i32
    §Q (>= n 0)
    §S (>= result 0)
    §IF{if1} (== n 0)
      §R 0
    §B{digit} §C{LastDigit} n
    §B{remaining} §C{SumDigitsPositive} (/ n 10)
    §R (+ digit remaining)

  §F{f004:SumDigits:pub} (i32:n) -> i32
    §S (>= result 0)
    §IF{if1} (< n 0)
      §B{posN} (- 0 n)
      §R §C{SumDigitsPositive} posN
    §R §C{SumDigitsPositive} n

