§M{m001:MathOps}
  §F{f001:Abs:pub} (i32:x) -> i32
    §S (>= result 0)
    §IF{if1} (< x 0)
      §R (- 0 x)
    §EL
      §R x

  §F{f002:Min:pub} (i32:a, i32:b) -> i32
    §IF{if1} (< a b)
      §R a
    §EL
      §R b

  §F{f003:Max:pub} (i32:a, i32:b) -> i32
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

