§M{m001:ReverseArray}
  §F{f001:SwapIndex:pub} (i32:length, i32:i) -> i32
    §Q (>= i 0)
    §Q (< i length)
    §R (- (- length 1) i)

  §F{f002:ShouldSwap:pub} (i32:left, i32:right) -> bool
    §R (< left right)

  §F{f003:MidPoint:pub} (i32:length) -> i32
    §Q (> length 0)
    §R (/ length 2)

