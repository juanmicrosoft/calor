§M{m001:ArrayOps}
  §F{f001:Max:pub} (i32:a, i32:b) -> i32
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

  §F{f002:Max3:pub} (i32:a, i32:b, i32:c) -> i32
    §IF{if1} (> a b)
      §IF{if2} (> a c)
        §R a
      §EL
        §R c
    §EL
      §IF{if3} (> b c)
        §R b
      §EL
        §R c

