§M{m001:Filter}
§F{f001:IsPositive:pub}
  §I{i32:value}
  §O{bool}
  §R (> value 0)
§/F{f001}
§F{f002:IsEven:pub}
  §I{i32:value}
  §O{bool}
  §R (== (% value 2) 0)
§/F{f002}
§F{f003:InRange:pub}
  §I{i32:value}
  §I{i32:min}
  §I{i32:max}
  §O{bool}
  §R (&& (>= value min) (<= value max))
§/F{f003}
§/M{m001}
