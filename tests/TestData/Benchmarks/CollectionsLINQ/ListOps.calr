§M{m001:ListOps}
  §F{f001:Sum:pub} (i32:a, i32:b) -> i32
    §R (+ a b)

  §F{f002:Count:pub} (i32:n) -> i32
    §S (>= result 0)
    §R n

  §F{f003:FirstOrDefault:pub} (i32:value, i32:defaultVal, bool:hasElements) -> i32
    §IF{if1} hasElements
      §R value
    §EL
      §R defaultVal

