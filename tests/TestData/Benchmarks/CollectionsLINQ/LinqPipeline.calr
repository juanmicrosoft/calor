§M{m001:LinqPipeline}
  §F{f001:SumPositive:pub} (i32:value, i32:acc) -> i32
    §IF{if1} (> value 0)
      §R (+ acc value)
    §EL
      §R acc

  §F{f002:CountEven:pub} (i32:value, i32:acc) -> i32
    §IF{if1} (== (% value 2) 0)
      §R (+ acc 1)
    §EL
      §R acc

  §F{f003:MaxOfTwo:pub} (i32:a, i32:b) -> i32
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

  §F{f004:AnyAboveThreshold:pub} (i32:value, i32:threshold) -> bool
    §R (> value threshold)

