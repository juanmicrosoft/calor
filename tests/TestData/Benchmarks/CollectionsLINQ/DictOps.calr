§M{m001:DictOps}
§F{f001:ContainsKey:pub}
  §I{bool:found}
  §O{bool}
  §R found
§/F{f001}
§F{f002:EntryCount:pub}
  §I{i32:count}
  §O{i32}
  §S (>= result 0)
  §R count
§/F{f002}
§F{f003:GetOrDefault:pub}
  §I{i32:value}
  §I{i32:defaultVal}
  §I{bool:exists}
  §O{i32}
  §IF{if1} exists → §R value
  §EL → §R defaultVal
  §/I{if1}
§/F{f003}
§/M{m001}
