§M{m001:OrderService}
  §F{f001:SaveOrder:pub} (str:orderId) -> void
    §E{cw}
    §P orderId

  §F{f002:NotifyCustomer:pub} (str:email, str:message) -> void
    §E{cw}
    §P email
    §P message

  §F{f003:ProcessOrder:pub} (str:orderId, str:email) -> void
    §E{cw}
    §C{SaveOrder} §A orderId §/C
    §C{NotifyCustomer} §A email §A "Order shipped" §/C

