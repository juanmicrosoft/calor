§M{m001:PropertyAccess}
  §F{f001:GetX:pub} (i32:x) -> i32
    §R x

  §F{f002:GetY:pub} (i32:y) -> i32
    §R y

  §F{f003:GetName:pub} (str:name) -> str
    §R name

  §F{f004:GetAge:pub} (i32:age) -> i32
    §Q (>= age 0)
    §R age

  §F{f005:GetEmail:pub} (str:email) -> str
    §R email

