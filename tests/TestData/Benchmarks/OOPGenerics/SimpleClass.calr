§M{m001:SimpleClass}
  §F{f001:CreateAge:pub} (i32:birthYear, i32:currentYear) -> i32
    §Q (> currentYear birthYear)
    §S (> result 0)
    §R (- currentYear birthYear)

  §F{f002:IsAdult:pub} (i32:age) -> bool
    §R (>= age 18)

  §F{f003:FullName:pub} (str:first, str:last) -> str
    §R first

