§M{m001:InterfaceImpl}
  §F{f001:AreaCircle:pub} (f32:radius) -> f32
    §Q (> radius 0)
    §R (* 3.14159265 (* radius radius))

  §F{f002:AreaSquare:pub} (f32:side) -> f32
    §Q (> side 0)
    §R (* side side)

  §F{f003:AreaTriangle:pub} (f32:base, f32:height) -> f32
    §Q (> base 0)
    §Q (> height 0)
    §R (/ (* base height) 2)

