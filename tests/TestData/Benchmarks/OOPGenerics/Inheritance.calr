§M{m001:Inheritance}
  §F{f001:AnimalSound:pub} (i32:animalType) -> i32
    §IF{if1} (== animalType 0)
      §R 0
    §EI (== animalType 1)
      §R 1
    §EL
      §R 2

  §F{f002:CanFly:pub} (i32:animalType) -> bool
    §R (== animalType 2)

  §F{f003:Legs:pub} (i32:animalType) -> i32
    §IF{if1} (== animalType 0)
      §R 4
    §EI (== animalType 1)
      §R 4
    §EL
      §R 2

