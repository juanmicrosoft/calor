§M{m001:ConstructorInit}
  §F{f001:ValidateWidth:pub} (f32:width) -> f32
    §Q (> width 0)
    §R width

  §F{f002:ValidateHeight:pub} (f32:height) -> f32
    §Q (> height 0)
    §R height

  §F{f003:Area:pub} (f32:width, f32:height) -> f32
    §Q (> width 0)
    §Q (> height 0)
    §S (> result 0)
    §R (* width height)

