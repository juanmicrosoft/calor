§M{m001:OverflowUnsafe}
  §F{f001:IncrementUnsafe:pub} (i32:x) -> i32
    §S (> result x)
    §R (+ x 1)

  §F{f002:DecrementUnsafe:pub} (i32:x) -> i32
    §S (< result x)
    §R (- x 1)

  §F{f003:DoubleUnsafe:pub} (i32:x) -> i32
    §Q (> x 0)
    §S (> result x)
    §R (* x 2)

  §F{f004:SquareUnsafe:pub} (i32:x) -> i32
    §Q (>= x 0)
    §S (>= result 0)
    §R (* x x)

  §F{f005:NegateUnsafe:pub} (i32:x) -> i32
    §Q (< x 0)
    §S (> result 0)
    §R (- 0 x)

  §F{f006:AddPositivesUnsafe:pub} (i32:x, i32:y) -> i32
    §Q (> x 0)
    §Q (> y 0)
    §S (> result 0)
    §R (+ x y)

