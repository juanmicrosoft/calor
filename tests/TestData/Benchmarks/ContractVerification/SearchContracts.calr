§M{m001:SearchContracts}
§F{f001:MidIndex:pub}
  §I{i32:low}
  §I{i32:high}
  §O{i32}
  §Q (<= low high)
  §Q (>= low 0)
  §S (>= result low)
  §S (<= result high)
  §R (+ low (/ (- high low) 2))
§/F{f001}
§F{f002:NarrowLeft:pub}
  §I{i32:mid}
  §I{i32:high}
  §O{i32}
  §Q (< mid high)
  §S (> result mid)
  §S (<= result high)
  §R (+ mid 1)
§/F{f002}
§F{f003:NarrowRight:pub}
  §I{i32:low}
  §I{i32:mid}
  §O{i32}
  §Q (< low mid)
  §S (>= result low)
  §S (< result mid)
  §R (- mid 1)
§/F{f003}
§/M{m001}
