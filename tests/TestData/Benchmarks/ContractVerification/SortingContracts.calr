§M{m001:SortingContracts}
§F{f001:IsSorted:pub}
  §I{i32:a}
  §I{i32:b}
  §O{bool}
  §R (<= a b)
§/F{f001}
§F{f002:IsPartitioned:pub}
  §I{i32:left}
  §I{i32:pivot}
  §I{i32:right}
  §O{bool}
  §R (&& (<= left pivot) (>= right pivot))
§/F{f002}
§F{f003:MergePreserves:pub}
  §I{i32:lenA}
  §I{i32:lenB}
  §O{i32}
  §Q (>= lenA 0)
  §Q (>= lenB 0)
  §S (== result (+ lenA lenB))
  §R (+ lenA lenB)
§/F{f003}
§/M{m001}
