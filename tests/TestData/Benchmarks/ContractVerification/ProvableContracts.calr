§M{m001:VerifiableMath}
  §F{f001:Abs:pub} (i32:x) -> i32
    §S (>= result 0)
    §IF{if1} (>= x 0)
      §R x
    §EL
      §R (- 0 x)

  §F{f002:Max:pub} (i32:a, i32:b) -> i32
    §S (>= result a)
    §S (>= result b)
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

  §F{f003:Min:pub} (i32:a, i32:b) -> i32
    §S (<= result a)
    §S (<= result b)
    §IF{if1} (< a b)
      §R a
    §EL
      §R b

  §F{f004:Clamp:pub} (i32:value, i32:min, i32:max) -> i32
    §Q (<= min max)
    §S (>= result min)
    §S (<= result max)
    §IF{if1} (< value min)
      §R min
    §EI (> value max)
      §R max
    §EL
      §R value

