§M{m001:AbsoluteContracts}
  §F{f001:AbsNonNeg:pub} (i32:x) -> i32
    §Q (> x (- 0 2147483647))
    §S (>= result 0)
    §IF{if1} (>= x 0)
      §R x
    §EL
      §R (- 0 x)

  §F{f002:AbsIdempotent:pub} (i32:x) -> i32
    §Q (>= x 0)
    §S (== result x)
    §R x

  §F{f003:TriangleInequality:pub} (i32:absA, i32:absB, i32:absSum) -> bool
    §Q (>= absA 0)
    §Q (>= absB 0)
    §Q (>= absSum 0)
    §R (<= absSum (+ absA absB))

