§M{m001:DivisionContracts}
§F{f001:SafeDiv:pub}
  §I{i32:a}
  §I{i32:b}
  §O{i32}
  §Q (!= b 0)
  §R (/ a b)
§/F{f001}
§F{f002:SafeMod:pub}
  §I{i32:a}
  §I{i32:b}
  §O{i32}
  §Q (!= b 0)
  §S (>= result 0)
  §R (% a b)
§/F{f002}
§F{f003:DivRemainder:pub}
  §I{i32:a}
  §I{i32:b}
  §O{i32}
  §Q (!= b 0)
  §R (- a (* (/ a b) b))
§/F{f003}
§/M{m001}
