§M{m001:DivisionContracts}
  §F{f001:SafeDiv:pub} (i32:a, i32:b) -> i32
    §Q (!= b 0)
    §R (/ a b)

  §F{f002:SafeMod:pub} (i32:a, i32:b) -> i32
    §Q (!= b 0)
    §S (>= result 0)
    §R (% a b)

  §F{f003:DivRemainder:pub} (i32:a, i32:b) -> i32
    §Q (!= b 0)
    §R (- a (* (/ a b) b))

