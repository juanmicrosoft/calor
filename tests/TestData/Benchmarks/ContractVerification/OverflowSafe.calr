§M{m001:OverflowSafe}
  §F{f001:IncrementSafe:pub} (i32:x) -> i32
    §Q (< x 2147483647)
    §S (> result x)
    §R (+ x 1)

  §F{f002:DecrementSafe:pub} (i32:x) -> i32
    §Q (> x -2147483648)
    §S (< result x)
    §R (- x 1)

  §F{f003:DoubleSafe:pub} (i32:x) -> i32
    §Q (> x 0)
    §Q (< x 1073741824)
    §S (> result x)
    §R (* x 2)

  §F{f004:SquareSafe:pub} (i32:x) -> i32
    §Q (>= x 0)
    §Q (<= x 46340)
    §S (>= result 0)
    §R (* x x)

  §F{f005:NegateSafe:pub} (i32:x) -> i32
    §Q (< x 0)
    §Q (> x -2147483648)
    §S (> result 0)
    §R (- 0 x)

  §F{f006:AddPositivesSafe:pub} (i32:x, i32:y) -> i32
    §Q (> x 0)
    §Q (< x 1073741824)
    §Q (> y 0)
    §Q (< y 1073741824)
    §S (> result 0)
    §R (+ x y)

  §F{f007:UnsignedNonNegative:pub} (u32:x) -> bool
    §S (== result true)
    §R (>= x 0)

