§M{m001:BitContracts}
  §F{f001:PowerOfTwo:pub} (i32:n) -> bool
    §Q (> n 0)
    §R (== (& n (- n 1)) 0)

  §F{f002:IsAligned:pub} (i32:value, i32:alignment) -> bool
    §Q (> alignment 0)
    §R (== (% value alignment) 0)

  §F{f003:ClearLowest:pub} (i32:n) -> i32
    §Q (> n 0)
    §R (& n (- n 1))

