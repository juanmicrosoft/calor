§M{m001:ListInvariant}
§F{f001:AddLength:pub}
  §I{i32:len}
  §O{i32}
  §Q (>= len 0)
  §S (> result len)
  §S (== result (+ len 1))
  §R (+ len 1)
§/F{f001}
§F{f002:RemoveLength:pub}
  §I{i32:len}
  §O{i32}
  §Q (> len 0)
  §S (< result len)
  §S (>= result 0)
  §R (- len 1)
§/F{f002}
§F{f003:ConcatLength:pub}
  §I{i32:lenA}
  §I{i32:lenB}
  §O{i32}
  §Q (>= lenA 0)
  §Q (>= lenB 0)
  §S (>= result lenA)
  §S (>= result lenB)
  §R (+ lenA lenB)
§/F{f003}
§/M{m001}
