§M{m001:CompactClass}
  §F{f001:Greet:pub} (str:name) -> str
    §E{cw}
    §P name
    §R name

  §F{f002:Square:pub} (i32:x) -> i32
    §S (>= result 0)
    §R (* x x)

  §F{f003:Max:pub} (i32:a, i32:b) -> i32
    §S (>= result a)
    §S (>= result b)
    §IF{if1} (> a b)
      §R a
    §EL
      §R b

