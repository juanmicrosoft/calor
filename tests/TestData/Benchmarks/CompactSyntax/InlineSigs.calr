§M{m001:InlineSigs}
§F{f001:Add:pub}
  §I{i32:a}
  §I{i32:b}
  §O{i32}
  §R (+ a b)
§/F{f001}
§F{f002:Multiply:pub}
  §I{i32:a}
  §I{i32:b}
  §O{i32}
  §R (* a b)
§/F{f002}
§F{f003:Negate:pub}
  §I{i32:x}
  §O{i32}
  §R (- 0 x)
§/F{f003}
§F{f004:IsZero:pub}
  §I{i32:x}
  §O{bool}
  §R (== x 0)
§/F{f004}
§/M{m001}
