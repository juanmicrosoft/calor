§M{m1:AllFeatures}
  §F{f1:Main:pub} () -> void
    §E{cw}
    §P "Starting"
    §B{x} 10
    §B{~y} 0
    §L{l1:i:1:10:1}
      §IF{i1} (> i 5)
        §P "high"
      §EI (== i 5)
        §P "middle"
      §EL
        §P "low"
      §B{~y} (+ y i)
    §P y

  §F{f2:Calculate:pub} (i32:a, i32:b) -> i32
    §Q (> a 0)
    §Q (> b 0)
    §S (> result 0)
    §B{sum} (+ a b)
    §B{product} (* a b)
    §R (+ sum product)

  §F{f3:Divide:priv} (i32:x, i32:y) -> i32
    §Q (!= y 0)
    §TR{t1}
      §R (/ x y)
    §CA{Exception:e}
      §R 0

