§M{m1:WhenFilter}
  §F{f1:FilteredHandler:pub} (i32:code) -> str
    §TR{t1}
      §TH "Error"
    §CA{Exception:ex} WHEN (== code 42)
      §R "special"
    §CA{Exception:ex}
      §R "general"

  §F{f2:MultipleFilters:pub} (i32:value) -> str
    §TR{t1}
      §TH "Error"
    §CA{Exception:ex} WHEN (< value 0)
      §R "negative"
    §CA{Exception:ex} WHEN (== value 0)
      §R "zero"
    §CA{Exception:ex} WHEN (> value 100)
      §R "large"
    §CA{Exception:ex}
      §R "normal"

  §F{f3:FilterWithLogicalOps:pub} (i32:x, i32:y) -> str
    §TR{t1}
      §TH "Error"
    §CA{Exception:ex} WHEN (&& (> x 0) (> y 0))
      §R "both positive"
    §CA{Exception:ex} WHEN (|| (< x 0) (< y 0))
      §R "at least one negative"
    §CA{Exception:ex}
      §R "default"

