§M{m1:NestedTry}
  §F{f1:OuterHandler:pub} (i32:x) -> i32
    §TR{t1}
      §TR{t2}
        §R (/ 100 x)
      §CA{DivideByZeroException:inner}
        §R -1
    §CA{Exception:outer}
      §R -2

  §F{f2:DeepNesting:pub} (i32:a, i32:b) -> i32
    §TR{t1}
      §TR{t2}
        §TR{t3}
          §R (/ (/ a b) b)
        §CA{DivideByZeroException:e3}
          §R -3
      §CA{ArithmeticException:e2}
        §R -2
    §CA{Exception:e1}
      §R -1

