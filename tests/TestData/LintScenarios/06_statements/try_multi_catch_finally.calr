§M{m1:MultiCatch}
  §F{f1:MultiHandler:pub} (str:input) -> i32
    §E{cw}
    §TR{t1}
      §R §C{Int32.Parse} §A input §/C
    §CA{ArgumentNullException:e1}
      §R -1
    §CA{FormatException:e2}
      §R -2
    §CA{OverflowException:e3}
      §R -3
    §CA{Exception}
      §R -99
    §FI
      §P "Done"

  §F{f2:OrderedCatches:pub} (i32:x) -> str
    §TR{t1}
      §R (/ 100 x)
    §CA{DivideByZeroException:e1}
      §R "divide by zero"
    §CA{ArithmeticException:e2}
      §R "arithmetic error"
    §CA{SystemException:e3}
      §R "system error"
    §CA{Exception:e4}
      §R "general error"

  §F{f3:CatchAllWithFinally:pub} () -> void
    §E{cw}
    §TR{t1}
      §TH "error"
    §CA{Exception}
      §P "caught"
      §RT
    §FI
      §P "finally"

