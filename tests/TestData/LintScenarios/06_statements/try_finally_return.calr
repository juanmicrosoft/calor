§M{m1:FinallyReturn}
  §F{f1:WithFinally:pub} (i32:x) -> i32
    §B{~result} 0
    §TR{t1}
      §B{~result} (+ x 10)
      §R result
    §FI
      §P "cleanup"

  §F{f2:FinallyNoReturn:pub} (i32:x) -> i32
    §B{~result} 0
    §TR{t1}
      §B{~result} (+ x 10)
    §CA{Exception:e}
      §B{~result} -1
    §FI
      §P "finally executed"
    §R result

  §F{f3:TryOnlyFinally:pub} () -> void
    §E{cw}
    §TR{t1}
      §P "try block"
    §FI
      §P "finally block"

