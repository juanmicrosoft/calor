§M{m1:Compare}
  §F{f1:IsEqual:pub} (i32:a, i32:b) -> bool
    §R (== a b)

  §F{f2:IsNotEqual:pub} (i32:a, i32:b) -> bool
    §R (!= a b)

  §F{f3:IsLess:pub} (i32:a, i32:b) -> bool
    §R (< a b)

  §F{f4:IsGreater:pub} (i32:a, i32:b) -> bool
    §R (> a b)

  §F{f5:IsLessEqual:pub} (i32:a, i32:b) -> bool
    §R (<= a b)

  §F{f6:IsGreaterEqual:pub} (i32:a, i32:b) -> bool
    §R (>= a b)

