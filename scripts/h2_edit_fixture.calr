§M{m001:MathLib}
  §F{f001:Add:pub} (i32:a, i32:b) -> i32
    §R (+ a b)

  §F{f002:Subtract:pub} (i32:a, i32:b) -> i32
    §R (- a b)

  §F{f003:Multiply:pub} (i32:x, i32:y) -> i32
    §R (* x y)

  §F{f004:Divide:pub} (i32:a, i32:b) -> i32
    §R (/ a b)

  §F{f005:Sign:pub} (i32:n) -> i32
    §IF{i01} (> n 0)
      §R 1
    §EI (< n 0)
      §R (- 0 1)
    §EL
      §R 0

